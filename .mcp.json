{
  "mcpServers": {
    "shopify-dev": {
      "command": "npx",
      "args": ["-y", "@shopify/dev-mcp@latest"],
      "env": {}
    },
    "shopify-store": {
      "command": "npx",
      "args": ["-y", "shopify-mcp@latest"],
      "env": {
        "SHOPIFY_ACCESS_TOKEN": "<your-shopify-admin-api-token>",
        "MYSHOPIFY_DOMAIN": "<your-store>.myshopify.com"
      }
    }
  }
}
